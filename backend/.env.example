# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These map directly to ${MONGODB_URI} and ${APP_JWT_SECRET} in application.properties.

# MongoDB Atlas connection string. Use your own cluster's connection string here —
# never reuse or commit a real password, even a rotated/old one.
MONGODB_URI=mongodb+srv://<user>:<password>@<your-cluster-host>/<db-name>?appName=<app-name>

# JWT signing secret — generate a fresh one, e.g.:  openssl rand -hex 32
# Do NOT reuse the old committed value.
APP_JWT_SECRET=<generate-with-openssl-rand-hex-32>
